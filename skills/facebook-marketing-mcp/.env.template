# Facebook Marketing API Configuration
# Get credentials from: https://developers.facebook.com/apps/

# App Credentials
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here

# Access Token (with ads_management permission)
FACEBOOK_ACCESS_TOKEN=your_long_lived_access_token_here

# Business and Account IDs
FACEBOOK_AD_ACCOUNT_ID=act_your_ad_account_id
FACEBOOK_BUSINESS_ID=your_business_id
FACEBOOK_PAGE_ID=your_page_id

# Campaign Defaults
DEFAULT_CAMPAIGN_OBJECTIVE=OUTCOME_AWARENESS  # or OUTCOME_TRAFFIC, OUTCOME_ENGAGEMENT, OUTCOME_LEADS, OUTCOME_APP_PROMOTION, OUTCOME_SALES
DEFAULT_DAILY_BUDGET=50.00
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=America/New_York

# Tracking and Analytics
FACEBOOK_PIXEL_ID=your_pixel_id
CONVERSION_API_ACCESS_TOKEN=your_conversion_api_token

# Webhook Configuration (optional)
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WEBHOOK_SECRET=your_webhook_secret

# Rate Limiting
API_CALLS_PER_HOUR=200
API_RETRY_DELAY=5

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/facebook-mcp.log
