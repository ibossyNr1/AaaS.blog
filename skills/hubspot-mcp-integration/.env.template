# HubSpot MCP Integration Environment Variables
# Copy this file to .env and fill in your credentials

# Required: Your HubSpot access token
# Generate at: https://app.hubspot.com/developer/
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token_here

# Required: Your HubSpot portal ID (found in URL or account settings)
HUBSPOT_PORTAL_ID=your_portal_id_here

# Optional: MCP server configuration
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=3000

# Optional: Data export settings
EXPORT_FORMAT=csv
EXPORT_DIR=./exports
