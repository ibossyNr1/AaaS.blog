# LinkedIn API Configuration
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_REFRESH_TOKEN=your_linkedin_refresh_token_here
LINKEDIN_REDIRECT_URI=https://your-domain.com/callback

# LinkedIn Account Settings
LINKEDIN_COMPANY_ID=123456789  # Your LinkedIn Company Page ID
LINKEDIN_USER_ID=your_linkedin_user_id
LINKEDIN_USER_EMAIL=your.email@company.com

# Content Settings
LINKEDIN_POST_SCHEDULE=09:00,13:00,17:00  # Optimal posting times (24h format)
LINKEDIN_POST_TIMEZONE=America/New_York
LINKEDIN_MAX_POSTS_PER_DAY=3
LINKEDIN_CONTENT_CATEGORIES=industry,thought-leadership,company-news

# Analytics Settings
LINKEDIN_ANALYTICS_DAYS=30
LINKEDIN_REPORT_FORMAT=csv
LINKEDIN_DATA_RETENTION_DAYS=90

# Lead Generation Settings
LINKEDIN_TARGET_INDUSTRIES=technology,finance,healthcare,education
LINKEDIN_TARGET_JOB_TITLES=CTO,CEO,VP,Director,Manager
LINKEDIN_MIN_CONNECTION_COUNT=500
LINKEDIN_MAX_CONNECTION_REQUESTS_PER_DAY=100

# Security Settings
LINKEDIN_API_TIMEOUT=30
LINKEDIN_RATE_LIMIT_DELAY=1
LINKEDIN_ENABLE_SSL=true

# Optional: Proxy Settings (if needed)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080
