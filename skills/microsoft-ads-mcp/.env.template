# Microsoft Advertising API Configuration
# Get credentials from: https://developers.ads.microsoft.com/

# OAuth 2.0 Credentials
MICROSOFT_ADS_CLIENT_ID=your_client_id_here
MICROSOFT_ADS_CLIENT_SECRET=your_client_secret_here
MICROSOFT_ADS_REFRESH_TOKEN=your_refresh_token_here

# Developer Token (from Microsoft Advertising Developer Portal)
MICROSOFT_ADS_DEVELOPER_TOKEN=your_developer_token_here

# Account Information
MICROSOFT_ADS_CUSTOMER_ID=your_customer_id_here
MICROSOFT_ADS_ACCOUNT_ID=your_account_id_here

# API Settings
MICROSOFT_ADS_ENVIRONMENT=production  # production or sandbox
MICROSOFT_ADS_API_VERSION=v13

# Reporting Settings
MICROSOFT_ADS_REPORT_TIMEZONE=UTC
MICROSOFT_ADS_DEFAULT_CURRENCY=USD

# Alert Thresholds
MICROSOFT_ADS_BUDGET_ALERT_PERCENT=80
MICROSOFT_ADS_CTR_THRESHOLD=2.0
MICROSOFT_ADS_CONVERSION_THRESHOLD=5.0

# Optimization Settings
MICROSOFT_ADS_MAX_BID_ADJUSTMENT=0.2
MICROSOFT_ADS_MIN_DAILY_BUDGET=10
MICROSOFT_ADS_TARGET_ROAS=400

# Logging
MICROSOFT_ADS_LOG_LEVEL=INFO
MICROSOFT_ADS_LOG_FILE=./logs/microsoft_ads.log
