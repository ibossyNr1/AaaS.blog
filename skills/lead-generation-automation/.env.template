# API Keys for Lead Generation Automation

# LinkedIn API (if using official API)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Email Finding Services
HUNTER_API_KEY=your_hunter_api_key
CLEARBIT_API_KEY=your_clearbit_api_key

# CRM Integration
SALESFORCE_CLIENT_ID=your_salesforce_client_id
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret
SALESFORCE_USERNAME=your_salesforce_username
SALESFORCE_PASSWORD=your_salesforce_password_and_token

HUBSPOT_API_KEY=your_hubspot_api_key

# Web Scraping Configuration
USER_AGENT=Mozilla/5.0 (compatible; LeadGenerator/1.0; +https://yourdomain.com)
REQUEST_DELAY=2  # seconds between requests
MAX_RETRIES=3

# Output Configuration
DEFAULT_OUTPUT_FORMAT=csv
ENABLE_DATA_ENRICHMENT=true
VALIDATE_EMAILS=true
