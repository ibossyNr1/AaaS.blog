# Social Media Automation API Keys
# Copy this file to .env and fill in your API keys

# OpenAI API (for content generation)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (alternative content generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Twitter/X API
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# LinkedIn API
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Facebook/Instagram API
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_account_id

# TikTok API (if available)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Pinterest API
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=your_reddit_user_agent

# Analytics APIs
GOOGLE_ANALYTICS_PROPERTY_ID=your_ga_property_id
GOOGLE_SERVICE_ACCOUNT_KEY=your_google_service_account_key_json

# Image Generation APIs
STABILITY_API_KEY=your_stability_api_key
REPLICATE_API_TOKEN=your_replicate_api_token

# Email for notifications
NOTIFICATION_EMAIL=your_email@example.com

# Timezone for scheduling (e.g., America/New_York, Europe/London)
TIMEZONE=UTC

# Content safety settings
CONTENT_SAFETY_LEVEL=medium  # low, medium, high
AI_DISCLOSURE_REQUIRED=true  # Add AI disclosure to generated content

# Rate limiting (posts per day per platform)
RATE_LIMIT_TWITTER=10
RATE_LIMIT_LINKEDIN=5
RATE_LIMIT_FACEBOOK=5
RATE_LIMIT_INSTAGRAM=3

# Backup settings
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily  # daily, weekly, monthly
BACKUP_LOCATION=./backups/

# Logging level
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
