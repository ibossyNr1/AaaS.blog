# Business Intelligence Automation Configuration

# Microsoft Power BI
POWERBI_CLIENT_ID=your_client_id_here
POWERBI_CLIENT_SECRET=your_client_secret_here
POWERBI_TENANT_ID=your_tenant_id_here
POWERBI_WORKSPACE_ID=your_workspace_id_here

# Tableau
TABLEAU_SERVER_URL=https://your-tableau-server.com
TABLEAU_SITE_NAME=your_site_name
TABLEAU_USERNAME=your_username
TABLEAU_PASSWORD=your_password
TABLEAU_PERSONAL_ACCESS_TOKEN_NAME=your_token_name
TABLEAU_PERSONAL_ACCESS_TOKEN_SECRET=your_token_secret

# Qlik Sense
QLIKSENSE_SERVER=https://your-qlik-server.com
QLIKSENSE_API_KEY=your_api_key_here
QLIKSENSE_APP_ID=your_app_id_here

# Zoho Analytics
ZOHO_ANALYTICS_CLIENT_ID=your_client_id_here
ZOHO_ANALYTICS_CLIENT_SECRET=your_client_secret_here
ZOHO_ANALYTICS_REFRESH_TOKEN=your_refresh_token_here
ZOHO_ANALYTICS_WORKSPACE=your_workspace_name

# Google Data Studio / Looker Studio
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_PROJECT_ID=your_google_project_id

# Database Connections
DATABASE_POSTGRESQL_URL=postgresql://user:password@host:port/database
DATABASE_MYSQL_URL=mysql://user:password@host:port/database
DATABASE_SQLITE_PATH=/path/to/database.db

# Email Configuration (for report distribution)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
REPORT_RECIPIENTS=recipient1@example.com,recipient2@example.com

# Storage Configuration
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
DROPBOX_ACCESS_TOKEN=your_dropbox_token_here
AWS_S3_BUCKET=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# General Settings
LOG_LEVEL=INFO
DATA_RETENTION_DAYS=90
REPORT_SCHEDULE="0 9 * * 1"  # Every Monday at 9 AM
TIMEZONE=UTC
