# Salesforce API Credentials
# Create a Connected App in Salesforce Setup to get Client ID and Secret
SALESFORCE_CLIENT_ID=your_connected_app_client_id
SALESFORCE_CLIENT_SECRET=your_connected_app_client_secret
SALESFORCE_USERNAME=your_salesforce_username
SALESFORCE_PASSWORD=your_password_with_security_token
SALESFORCE_INSTANCE_URL=https://yourdomain.my.salesforce.com
SALESFORCE_API_VERSION=59.0

# Optional: Custom Object API Names
SALESFORCE_CUSTOM_LEAD_OBJECT=Lead__c
SALESFORCE_CUSTOM_OPPORTUNITY_OBJECT=Opportunity__c

# Optional: Webhook URLs for notifications
SALESFORCE_WEBHOOK_URL=https://your-webhook.com/salesforce
