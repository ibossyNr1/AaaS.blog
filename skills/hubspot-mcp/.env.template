# HubSpot API Configuration
# Get credentials from: https://developers.hubspot.com/docs/api/overview

# OAuth Access Token or Private App Access Token
HUBSPOT_ACCESS_TOKEN=your_access_token_here

# HubSpot Portal ID (found in URL: https://app.hubspot.com/contacts/{PORTAL_ID})
HUBSPOT_PORTAL_ID=your_portal_id_here

# Optional: API Base URL (default is https://api.hubapi.com)
# HUBSPOT_API_BASE=https://api.hubapi.com

# Optional: Timeout settings (in seconds)
# HUBSPOT_TIMEOUT=30
# HUBSPOT_MAX_RETRIES=3
