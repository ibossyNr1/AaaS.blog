# Twitter/X API Configuration
# Get credentials from: https://developer.twitter.com/en/portal/dashboard

TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Optional: App-specific settings
TWITTER_APP_ID=your_app_id_here
TWITTER_CLIENT_ID=your_client_id_here
TWITTER_CLIENT_SECRET=your_client_secret_here

# Rate limiting settings
RATE_LIMIT_TWEETS=50
RATE_LIMIT_SEARCH=180
RATE_LIMIT_STREAM=50

# Business settings
BRAND_HANDLE=your_brand_handle
COMPETITOR_HANDLES=competitor1,competitor2,competitor3
KEYWORDS_TO_MONITOR=product,service,brandname
